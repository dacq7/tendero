# ─────────────────────────────────────────────────────────────
# Tendero — variables de entorno (PLANTILLA). Copiar a:
#   backend/.env        (vars de backend + DB)
#   frontend/.env.local (solo las NEXT_PUBLIC_*)
# NUNCA pongas valores reales en este archivo ni lo borres del repo.
# ─────────────────────────────────────────────────────────────

# ── Base de datos (Postgres por Docker, puerto 5436) ──
DATABASE_URL=postgresql+psycopg://tendero:tendero@localhost:5436/tendero

# ── Auth (Fase 0) ──
# Genera uno real con:  openssl rand -hex 32
JWT_SECRET=cambia-esto-por-un-secreto-de-32-bytes
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# ── CORS / red ──
BACKEND_PORT=8020
FRONTEND_ORIGIN=http://localhost:3001

# ── Frontend (expuesto al navegador; va en frontend/.env.local) ──
NEXT_PUBLIC_API_URL=http://localhost:8020

# ── Pagos Wompi (Fase 3 — sandbox; llave privada SOLO en servidor) ──
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=

# ── Facturación DIAN vía PT (Fase 4) ──
FISCAL_PROVIDER=mock        # mock | real
FISCAL_PT_API_URL=
FISCAL_PT_API_KEY=
