# ─────────────────────────────────────────────────────────────
# Tendero — variables de entorno (PLANTILLA). Copiar a:
#   backend/.env        (vars de backend + DB)
#   frontend/.env.local (solo las NEXT_PUBLIC_*)
# NUNCA pongas valores reales en este archivo ni lo borres del repo.
#
# IMPORTANTE (hardening Fase 6 B.1): los secretos marcados [REQUERIDO] NO tienen
# valor por defecto en el código. Si faltan en back/.env, el backend FALLA al
# arrancar con un error claro (no opera con credenciales conocidas). Hay que
# generarlos y ponerlos en backend/.env antes de levantar el backend, el seed o
# los tests. Los valores de prueba de Wompi/DIAN sirven SOLO para el modo `mock`.
# ─────────────────────────────────────────────────────────────

# ── Entorno de despliegue ──
# development | test | production. En 'production' se emite HSTS y los proveedores
# 'real' exigen sus credenciales. Por defecto 'development'.
APP_ENV=development

# ── Base de datos (Postgres por Docker, puerto 5436) ── [REQUERIDO]
DATABASE_URL=postgresql+psycopg://tendero:tendero@localhost:5436/tendero

# URL para la suite de tests (opcional). Si no se define, se deriva de
# DATABASE_URL añadiendo el sufijo `_test` al nombre de la base. Su nombre DEBE
# terminar en `_test` (la suite hace DROP/CREATE de esa base).
# TEST_DATABASE_URL=postgresql+psycopg://tendero:tendero@localhost:5436/tendero_test

# ── Auth (Fase 0) ── [REQUERIDO]
# Genera uno real con:  openssl rand -hex 32  (sin él, el backend no arranca)
JWT_SECRET=cambia-esto-por-un-secreto-de-32-bytes
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# ── CORS / red ──
BACKEND_PORT=8020
FRONTEND_ORIGIN=http://localhost:3001

# ── Frontend (van en frontend/.env.local) ──
# URL del backend usada SOLO server-side por el BFF (route handlers + proxy).
# Los JWT viven en cookies httpOnly; el navegador nunca llama directo al backend.
BACKEND_URL=http://localhost:8020
# (Compat) URL pública; el BFF la usa como fallback si falta BACKEND_URL.
NEXT_PUBLIC_API_URL=http://localhost:8020

# ── Pagos Wompi (Fase 3 — sandbox; llave privada SOLO en servidor) ──
# ⚠ Los valores de abajo son de PRUEBA y PÚBLICOS: con ellos cualquiera puede
# firmar un webhook válido. En un despliegue real, reemplaza TODOS los secretos
# por los de tu cuenta Wompi (hardening de Fase 6) y nunca los subas al repo.
# Proveedor: mock (demo de portafolio, sin llaves) | real (API Wompi sandbox).
WOMPI_PROVIDER=mock
WOMPI_PUBLIC_KEY=pub_test_demo
WOMPI_PRIVATE_KEY=
# Secreto para firmar la integridad de transacciones. [REQUERIDO] (lo usa el mock).
WOMPI_INTEGRITY_SECRET=integrity_test_secret
# Secreto para validar la firma de los eventos de webhook. [REQUERIDO].
WOMPI_EVENTS_SECRET=events_test_secret

# ── Facturación DIAN vía PT (Fase 4) ──
# mock = documentos simulados SIN validez fiscal (demo). real = API del PT (Alanube/
# Factus…), credenciales SOLO en servidor; no corre sin ellas.
FISCAL_PROVIDER=mock        # mock | real
FISCAL_PT_API_URL=
FISCAL_PT_API_KEY=
# Secreto para el CUFE SIMULADO del mock. [REQUERIDO] (de prueba; sin validez fiscal).
FISCAL_CUFE_SECRET=cufe_demo_secret
